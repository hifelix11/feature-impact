# Supabase (use your cloud project values from https://supabase.com/dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bloomreach Engagement
BLOOMREACH_API_URL=https://api.exponea.com
BLOOMREACH_PROJECT_TOKEN=your-project-token
BLOOMREACH_API_KEY_ID=your-api-key-id
BLOOMREACH_API_SECRET=your-api-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App
APP_ENV=development
SYNC_INTERVAL_HOURS=6
DEFAULT_COMPARISON_WINDOW_DAYS=14

# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
